# ============================================================
# .env.example — Variables de entorno para Ciphie
# Copia este archivo como ".env" y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# Clave maestra de cifrado para los secretos almacenados (Fernet/AES).
# Genera una con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=cambia_esto_por_una_clave_fernet_real

# SMTP — para enviar códigos de verificación por email (registro y 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion

# Twilio — para enviar códigos por SMS (opcional)
# Crea una cuenta en https://twilio.com y obtén estas credenciales
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890
